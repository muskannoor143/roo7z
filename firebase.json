{
  "emulators": {
    "auth": {
      "port": 9099
    },
    "hosting": {
      "port": 5059
    },
    "dataconnect": {
      "port": 9399
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  },
  "dataconnect": {
    "source": "./dataconnect"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "redirects": [
      {
        "source": "/",
        "destination": "/jewelrify.html",
        "type": 301
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "README.md",
      "TODO.md",
      "dev.nix",
      "dataconnect/**",
      "app/**",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
